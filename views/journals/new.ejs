<%layout('layouts/boilerplate')-%>
<div class='col-md-8 offset-2'>
    <form action='/journals' method="post"  class='form-validate' novalidate>
        <label class='form-label' for="title">Title</label>
        <input class='form-control ' type="text" id="title" placeholer='Title' name='title' required></input>
        <div class="invalid-feedback">
            Please include a title for your entry.
        </div>
        
        <label class='mt-3' for="entry">Journal Entry</label>
        <textarea class="form-control " type="text" id="entry" placeholer='Journal Entry' name='entry' required></textarea>
        <div class="invalid-feedback">
            Uh oh! You left your journal entry empty.
        </div>
     
        <button class='btn btn-primary mt-3'>Add</button>
    </form>
    




</div> 
</body>
</html>