<%layout('layouts/boilerplate')-%>
    <form action='/journals/<%=editEntry.id%>?_method=PATCH' method="post">
        <label for="title">Title</label>
        <input type="text" id="title" placeholer='Title' name='title' value='<%=editEntry.title%>'>
        <label for="journal">Journal Entry</label>
        <input type="text" id="journal" placeholer='Journal' name='journal' value='<%=editEntry.journal%>'>
        <button>Update</button>
    
    </form>
    <a href="/journals/<%=editEntry.id%>">Cancel</a>
    <form action="/journals/<%=editEntry.id%>?_method=DELETE" method="post">
    <button>Delete</button>
    </form>
